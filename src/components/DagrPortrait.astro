---
import type DagrDataSpec from "../data/dagr-data.json";
type ClassData = (typeof DagrDataSpec)["classes"][number];
type Props = { classData: ClassData };
const { classData } = Astro.props;
---

<article data-glamour={classData.glamourSet}>
  <img
    src={`/dagr-portraits/${classData.portrait}`}
    height="410"
    width="250"
    class={classData.category.toLowerCase()}
  />
  <h4>{classData.name}</h4>
</article>
<style>
  article {
    position: relative;
    cursor: pointer;
  }
  h4 {
    text-align: center;
    font-size: 1.3rem;
  }
  img {
    box-shadow: 0px 0px 19px 1px var(--class-color);
  }
  .tank {
    --class-color: #137;
  }
  .healer {
    --class-color: #184;
  }
  .dps {
    --class-color: #911;
  }
</style>
