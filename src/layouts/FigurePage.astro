---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Gallery from '../components/Gallery.astro';
import Table from '../components/Table.astro';

type Props = CollectionEntry<'figures'>['data'];

const { title, description, pubDate, figureImage, boxImages, character, figureLine, mfcLink, series } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 1450px;
				margin: 0;
			}
			article {
				display: grid;
				grid-template-columns: 600px auto;
				grid-template-rows: min-content;
			}
			.image {
				width: 100%;
				padding-bottom: 1em;
				.selected {
					border-radius: 8px;
				}
			}
			.prose {
				width: 100%;
				height: 100%;
				min-width: 250px;
				min-height: fit-content;
				margin: 0;
				padding: 1em;
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
				box-sizing: border-box;
			}
			.title {
				margin-bottom: 1em;
				text-align: center;
				line-height: 1;
			}
			.title h2 {
				margin: 0 0 0.5em 0;
				font-size: 2.5rem;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.spacer {
				flex-grow: 1;
			}

			.details {
				width: 100%;
				height: fit-content;
			}
			@media screen and (max-width: 1100px) {
				article {
					max-width: clamp(300px, 100%, 600px);
					grid-template-columns: clamp(300px, 100%, 600px);
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="image">
					<Gallery imgSrcs={[figureImage, boxImages ?? []].flat()}/>
				</div>
				<div class="prose">
					<section class="title">
						<h2>{title}</h2>
						<p class="date">Added on <FormattedDate date={pubDate}/></p>
						<hr />
					</section>
					<slot />
					<div class="spacer"/>
					<section class="details">
						<h4>Details</h4>
						<Table data={{
							Character: character,
							Series: series,
							...(figureLine ? {'Figure Line': figureLine} : {}),
							'MyFigureCollection': mfcLink
						}}/>
					</section>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
